# ============================================================================
# MinIO (S3-compatible object storage for DVC)
# ============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=mlops-artifacts

# ============================================================================
# DVC Remote Configuration
# ============================================================================
DVC_REMOTE_NAME=minio-local
DVC_REMOTE_URL=s3://mlops-artifacts/dvc

# ============================================================================
# DVC Remote Credentials (S3)
# ============================================================================
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ============================================================================
# Training Pipeline Configuration
# ============================================================================
TRAIN_RAW_DATA_PATH=data/train_raw
SIMULATION_RAW_DATA_PATH=data/simulation_raw/2019-Nov.csv.gz
RETRAIN_RAW_DATA_DIR=data/retrain_raw
RETRAIN_DATA_DIR=data/retrain
RETRAIN_WINDOW_DAYS=7
BRONZE_DATA_PATH=data/bronze/events.parquet
SILVER_DATA_PATH=data/silver/events.parquet
GOLD_DATA_DIR=data/gold

# Prediction contract: 10-minute window for next event
PREDICTION_HORIZON_MINUTES=10

# Raw window selection for bronze ingestion
DATA_WINDOW_PROFILE=training
TRAINING_WINDOW_START=2019-10
TRAINING_WINDOW_END=2019-10
DEV_SMOKE_WINDOW_START=2019-10
DEV_SMOKE_WINDOW_END=2019-10
REPLAY_WINDOW_START=2019-11
REPLAY_WINDOW_END=2019-11

# ============================================================================
# Week 3 Online Services
# ============================================================================
KAFKA_BROKER=redpanda:9092
RAW_EVENTS_TOPIC=raw_events
LATE_EVENTS_TOPIC=late_events
REDIS_URL=redis://redis:6379/0
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops
POSTGRES_DB=mlops
POSTGRES_DSN=postgresql://mlops:mlops@postgres:5432/mlops
SESSION_TTL_SECONDS=1800
LATE_EVENT_THRESHOLD_SECONDS=60
REPLAY_LIMIT=1000
API_KEY=local-dev-api-key
MLFLOW_SERVING_BUNDLE_URI=runs:/replace-with-week3-smoke-run
